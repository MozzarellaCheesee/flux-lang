class People {
    name: &str;
    age: int16;

    pub fnc new(name_: &str, age_: int16) -> People {
        return People {
            name: name_,
            age: age_,
        };
    }

    pub fnc get_name(self) -> &str {
        return self.name;
    }
}

fnc main() -> int32 {
    let p = People.new("John", 18);
    println(p.get_name());
    return 0;
}